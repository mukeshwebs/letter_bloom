{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "destination": "/privacy-policy.html"
      }
    ]
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "letterbloom-727346",
          "appId": "1:230814657090:android:52bab507d2f0190350dbdb",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "letterbloom-727346",
          "appId": "1:230814657090:ios:cf146c233c05576f50dbdb",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "letterbloom-727346",
          "configurations": {
            "android": "1:230814657090:android:52bab507d2f0190350dbdb",
            "ios": "1:230814657090:ios:cf146c233c05576f50dbdb",
            "web": "1:230814657090:web:c8cc643fe4b94cd850dbdb"
          }
        }
      }
    }
  }
}